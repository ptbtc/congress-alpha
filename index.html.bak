/* ═══════════════════════════════
   UTILITY FUNCTIONS
   ═══════════════════════════════ */

function fmt(n,dec=2){return n.toFixed(dec)}
function fmtPct(n,dec=2){return (n>=0?'+':'')+n.toFixed(dec)+'%'}
function fmtMoney(n){
  if(n>=1000000)return '$'+fmt(n/1000000,1)+'M';
  if(n>=1000)return '$'+(n/1000).toFixed(0)+'K';
  return '$'+n.toLocaleString();
}
function daysSince(dateStr){
  const d=new Date(dateStr);const now=new Date('2026-03-31');
  return Math.floor((now-d)/(1000*60*60*24));
}

/* ═══════════════════════════════
   THEME & SHARE
   ═══════════════════════════════ */

function toggleTheme(){
  const t=document.documentElement.dataset.theme==='dark'?'light':'dark';
  document.documentElement.dataset.theme=t;
  document.getElementById('theme-btn').textContent=t==='dark'?'☀ Light':'🌙 Dark';
  initAllCharts();
}
function shareResearch(){
  navigator.clipboard.writeText(window.location.href);
  const t=document.getElementById('share-toast');
  t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2000);
}
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}

/* ═══════════════════════════════
   CHART HELPERS
   ═══════════════════════════════ */

function isDark(){return document.documentElement.dataset.theme==='dark'}
function gridColor(){return isDark()?'rgba(255,255,255,.09)':'rgba(0,0,0,.08)'}
function tickColor(){return isDark()?'#64748b':'#94a3b8'}
function fontColor(){return isDark()?'#cbd5e1':'#475569'}

const TEAL='#14b8a6',TEAL_A='rgba(20,184,166,.5)',TEAL_BG='rgba(20,184,166,.12)';
const PURPLE='#a78bfa',PURPLE_A='rgba(167,139,250,.5)',PURPLE_BG='rgba(167,139,250,.12)';
const AMBER='#f59e0b',RED='#ef4444',GREEN='#22c55e',BLUE='#3b82f6';

function baseOpts(){
  return{
    responsive:true,maintainAspectRatio:true,
    animation:{duration:800,easing:'easeOutQuart'},
    plugins:{
      legend:{display:true,labels:{color:fontColor(),font:{family:"'Source Serif Pro',serif",size:12},boxWidth:14,padding:16}},
      tooltip:{
        backgroundColor:isDark()?'#1e293b':'#fff',
        titleColor:isDark()?'#e2e8f0':'#1e293b',
        bodyColor:isDark()?'#94a3b8':'#475569',
        borderColor:isDark()?'#334155':'#e2e8f0',borderWidth:1,
        padding:12,cornerRadius:8,
        titleFont:{family:"'Playfair Display',serif",size:13,weight:'600'},
        bodyFont:{family:"'JetBrains Mono',monospace",size:11},
      }
    },
    scales:{
      x:{grid:{color:gridColor()},ticks:{color:tickColor(),font:{family:"'JetBrains Mono',monospace",size:10}}},
      y:{grid:{color:gridColor()},ticks:{color:tickColor(),font:{family:"'JetBrains Mono',monospace",size:10}}}
    }
  };
}

let charts={};
function destroyAll(){Object.values(charts).forEach(c=>{if(c)c.destroy()});charts={}}

function initAllCharts(){
  destroyAll();

  // Chart 1: Lag Decay — Insider vs Copycat
  const ctx1=document.getElementById('chart-lag').getContext('2d');
  charts.lag=new Chart(ctx1,{
    type:'bar',
    data:{
      labels:['At Disclosure\n(T+0)','T+30 Days','T+60 Days','T+90 Days'],
      datasets:[
        {
          label:'Insider (from trade date)',
          data:[2.12,2.17,2.58,3.40],
          backgroundColor:TEAL_A,borderColor:TEAL,borderWidth:1.5,borderRadius:6,
        },
        {
          label:'Copycat (from disclosure)',
          data:[0,0.71,1.52,2.43],
          backgroundColor:PURPLE_A,borderColor:PURPLE,borderWidth:1.5,borderRadius:6,
        },
        {
          label:'Purchases Only (insider)',
          data:[null,3.24,3.52,4.16],
          backgroundColor:'rgba(34,197,94,.4)',borderColor:GREEN,borderWidth:1.5,borderRadius:6,
        }
      ]
    },
    options:{
      ...baseOpts(),
      plugins:{
        ...baseOpts().plugins,
        tooltip:{
          ...baseOpts().plugins.tooltip,
          callbacks:{
            label:function(ctx){return ctx.dataset.label+': '+fmtPct(ctx.parsed.y)}
          }
        }
      },
      scales:{
        ...baseOpts().scales,
        y:{...baseOpts().scales.y,beginAtZero:true,title:{display:true,text:'Mean Excess Return (%)',color:tickColor(),font:{family:"'JetBrains Mono',monospace",size:11}}}
      }
    }
  });

  // Chart 2: Monthly Excess Returns (bar chart)
  const ctx2=document.getElementById('chart-cumulative').getContext('2d');
  charts.cumulative=new Chart(ctx2,{
    type:'bar',
    data:{
      labels:MONTHLY_RETURNS.map(d=>d.month),
      datasets:[{
        label:'Mean Excess Return 90d (%)',
        data:MONTHLY_RETURNS.map(d=>d.excess90),
        backgroundColor:MONTHLY_RETURNS.map(d=>d.excess90>=0?'rgba(20,184,166,.6)':'rgba(239,68,68,.5)'),
        borderColor:MONTHLY_RETURNS.map(d=>d.excess90>=0?TEAL:RED),
        borderWidth:1.5,borderRadius:3,
      }]
    },
    options:{
      ...baseOpts(),
      plugins:{
        ...baseOpts().plugins,
        legend:{display:false},
        tooltip:{
          ...baseOpts().plugins.tooltip,
          callbacks:{
            title:function(ctx){return ctx[0].label},
            label:function(ctx){
              const d=MONTHLY_RETURNS[ctx.dataIndex];
              return [`Excess: ${fmtPct(d.excess90)}`,`Trades: ${d.n}`];
            }
          }
        }
      },
      scales:{
        x:{...baseOpts().scales.x,ticks:{...baseOpts().scales.x.ticks,maxRotation:60,minRotation:45}},
        y:{...baseOpts().scales.y,title:{display:true,text:'Mean Excess Return (%)',color:tickColor(),font:{family:"'JetBrains Mono',monospace",size:11}}}
      }
    }
  });

  // Chart 3: Party Comparison
  const ctx3=document.getElementById('chart-party').getContext('2d');
  charts.party=new Chart(ctx3,{
    type:'bar',
    data:{
      labels:['Republican (n=40)','Democrat (n=28)','All Trades (n=68)'],
      datasets:[{
        label:'Mean Excess Return 90d (%)',
        data:[7.10,-1.89,3.40],
        backgroundColor:[
          'rgba(239,68,68,.5)',
          'rgba(59,130,246,.5)',
          'rgba(20,184,166,.5)'
        ],
        borderColor:[RED,BLUE,TEAL],
        borderWidth:1.5,borderRadius:6,
      }]
    },
    options:{
      ...baseOpts(),
      plugins:{
        ...baseOpts().plugins,
        legend:{display:false},
        tooltip:{
          ...baseOpts().plugins.tooltip,
          callbacks:{label:function(ctx){return 'Excess: '+fmtPct(ctx.parsed.y)}}
        }
      },
      scales:{
        ...baseOpts().scales,
        y:{...baseOpts().scales.y,title:{display:true,text:'Mean Excess Return (%)',color:tickColor(),font:{family:"'JetBrains Mono',monospace",size:11}}}
      }
    }
  });

  // Chart 4: Sector Alpha (horizontal bars)
  const sectors=[
    {s:'Consumer Discretionary',a:10.21,n:8},{s:'Financials',a:8.84,n:5},
    {s:'Commodities',a:8.10,n:1},{s:'Industrials',a:6.52,n:4},
    {s:'Energy',a:4.08,n:5},{s:'Technology',a:2.65,n:32},
    {s:'Healthcare',a:2.02,n:8},{s:'Broad Market',a:0.0,n:2},
    {s:'Materials',a:-11.26,n:1},{s:'Communication Svcs',a:-19.43,n:2}
  ];
  const ctx4=document.getElementById('chart-sectors').getContext('2d');
  charts.sectors=new Chart(ctx4,{
    type:'bar',
    data:{
      labels:sectors.map(d=>d.s),
      datasets:[{
        label:'Mean Excess Return 90d (%)',
        data:sectors.map(d=>d.a),
        backgroundColor:sectors.map(d=>{
          if(d.a>0)return `rgba(20,184,166,${Math.min(.2+d.a/15,.8)})`;
          return `rgba(239,68,68,${Math.min(.2+Math.abs(d.a)/25,.8)})`;
        }),
        borderColor:sectors.map(d=>d.a>=0?TEAL:RED),
        borderWidth:1.5,borderRadius:4,
      }]
    },
    options:{
      ...baseOpts(),indexAxis:'y',
      scales:{
        x:{...baseOpts().scales.x,title:{display:true,text:'Mean Excess Return (%)',color:tickColor(),font:{family:"'JetBrains Mono',monospace",size:11}}},
        y:{...baseOpts().scales.y,grid:{display:false}}
      },
      plugins:{
        ...baseOpts().plugins,
        legend:{display:false},
        tooltip:{
          ...baseOpts().plugins.tooltip,
          callbacks:{
            label:function(ctx){
              const d=sectors[ctx.dataIndex];
              return [`Excess: ${fmtPct(d.a)}`,`Trades: ${d.n}`];
            }
          }
        }
      }
    }
  });

  // Chart 5: Top Traders Bubble
  const topTraders=TRADER_STATS.filter(t=>Math.abs(t.meanExcess)>2).slice(0,15);
  const ctx5=document.getElementById('chart-traders').getContext('2d');
  const maxVol=Math.max(...topTraders.map(t=>t.volume));
  charts.traders=new Chart(ctx5,{
    type:'bubble',
    data:{
      datasets:[
        {
          label:'Democrats',
          data:topTraders.filter(d=>d.party==='D').map(d=>({
            x:d.n,y:d.meanExcess,r:Math.max(4,Math.sqrt(d.volume/maxVol)*30),name:d.trader
          })),
          backgroundColor:'rgba(59,130,246,.45)',borderColor:BLUE,borderWidth:1.5,
        },
        {
          label:'Republicans',
          data:topTraders.filter(d=>d.party==='R').map(d=>({
            x:d.n,y:d.meanExcess,r:Math.max(4,Math.sqrt(d.volume/maxVol)*30),name:d.trader
          })),
          backgroundColor:'rgba(239,68,68,.4)',borderColor:RED,borderWidth:1.5,
        }
      ]
    },
    options:{
      ...baseOpts(),
      scales:{
        x:{...baseOpts().scales.x,title:{display:true,text:'Number of Trades',color:tickColor(),font:{family:"'JetBrains Mono',monospace",size:11}}},
        y:{...baseOpts().scales.y,title:{display:true,text:'Mean Excess Return 90d (%)',color:tickColor(),font:{family:"'JetBrains Mono',monospace",size:11}}}
      },
      plugins:{
        ...baseOpts().plugins,
        tooltip:{
          ...baseOpts().plugins.tooltip,
          callbacks:{
            label:function(ctx){
              const d=ctx.raw;
              return `${d.name}: ${ctx.parsed.x} trades, ${fmtPct(ctx.parsed.y)} excess`;
            }
          }
        }
      }
    }
  });

  // Simulator chart
  initSimChart();
}

/* ═══════════════════════════════
   POPULATE TABLES
   ═══════════════════════════════ */

function populateTraderTable(){
  const tbody=document.getElementById('trader-table-body');
  if(!tbody)return;
  tbody.innerHTML=TRADER_STATS.map(t=>`
    <tr>
      <td>${t.trader}</td>
      <td><span class="tag tag-${t.party==='D'?'dem':'rep'}">${t.party==='D'?'DEM':'REP'}</span></td>
      <td>${t.chamber}</td>
      <td class="num">${t.n}</td>
      <td class="num">${fmtMoney(t.volume)}</td>
      <td class="num ${t.meanExcess>=0?'positive':'negative'}">${fmtPct(t.meanExcess)}</td>
      <td class="num">${fmt(t.winRate,1)}%</td>
      <td class="num ${t.best>=0?'positive':'negative'}">${fmtPct(t.best)}</td>
      <td class="num ${t.worst>=0?'positive':'negative'}">${fmtPct(t.worst)}</td>
    </tr>
  `).join('');
}

function populateRecentTrades(){
  const tbody=document.getElementById('recent-trades-body');
  if(!tbody)return;
  const sorted=[...TRADES].sort((a,b)=>new Date(b.date)-new Date(a.date)).slice(0,20);
  tbody.innerHTML=sorted.map(t=>{
    const arrow=t.excess90>=0?'up':'down';
    const arrowChar=t.excess90>=0?'▲':'▼';
    return `<tr>
      <td style="white-space:nowrap">${t.date}</td>
      <td>${t.trader}</td>
      <td><span class="tag tag-${t.party==='D'?'dem':'rep'}">${t.party==='D'?'DEM':'REP'}</span></td>
      <td class="mono">${t.ticker}</td>
      <td>${t.type}</td>
      <td class="num">${fmtMoney(t.amount)}</td>
      <td class="num">${t.lagDays}d</td>
      <td class="num"><span class="trade-arrow ${arrow}">${arrowChar}</span><span class="${t.excess90>=0?'positive':'negative'}">${fmtPct(t.excess90)}</span></td>
    </tr>`;
  }).join('');
}

function populateExplorer(){
  // Populate filter dropdowns
  const sectors=[...new Set(TRADES.map(t=>t.sector))].sort();
  const traders=[...new Set(TRADES.map(t=>t.trader))].sort();
  const sectorSelect=document.getElementById('filter-sector');
  const traderSelect=document.getElementById('filter-trader');
  sectors.forEach(s=>{const o=document.createElement('option');o.value=s;o.textContent=s;sectorSelect.appendChild(o)});
  traders.forEach(t=>{const o=document.createElement('option');o.value=t;o.textContent=t;traderSelect.appendChild(o)});

  renderExplorer(TRADES);
}

function renderExplorer(data){
  const tbody=document.getElementById('explorer-body');
  if(!tbody)return;
  const sorted=[...data];
  if(explorerSortCol>=0){
    const keys=['','date','trader','party','ticker','sector','type','amount','excess90'];
    const key=keys[explorerSortCol];
    if(key){
      sorted.sort((a,b)=>{
        let av=a[key],bv=b[key];
        if(key==='date')return explorerSortAsc?new Date(av)-new Date(bv):new Date(bv)-new Date(av);
        if(typeof av==='number')return explorerSortAsc?av-bv:bv-av;
        return explorerSortAsc?String(av).localeCompare(String(bv)):String(bv).localeCompare(String(av));
      });
    }
  } else {
    sorted.sort((a,b)=>new Date(b.date)-new Date(a.date));
  }
  tbody.innerHTML=sorted.map((t,i)=>{
    const mainRow=`<tr class="explorer-row" data-idx="${i}">
      <td><button class="expand-btn" onclick="toggleDetail(this,${i})">+</button></td>
      <td style="white-space:nowrap">${t.date}</td>
      <td>${t.trader}</td>
      <td><span class="tag tag-${t.party==='D'?'dem':'rep'}">${t.party==='D'?'DEM':'REP'}</span></td>
      <td class="mono">${t.ticker}</td>
      <td>${t.sector}</td>
      <td>${t.type}</td>
      <td class="num">${fmtMoney(t.amount)}</td>
      <td class="num ${t.excess90>=0?'positive':'negative'}">${fmtPct(t.excess90)}</td>
    </tr>`;
    const detailRow=`<tr class="trade-detail-row" id="detail-${i}">
      <td colspan="9">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
          <div>
            <strong>${t.company}</strong> (${t.ticker})<br>
            <span style="color:var(--text-dim)">Sector:</span> ${t.sector}<br>
            <span style="color:var(--text-dim)">Committee:</span> ${t.committee}<br>
            <span style="color:var(--text-dim)">Source:</span> ${t.source}<br>
            <span style="color:var(--text-dim)">Disclosure Date:</span> ${t.disclosure}<br>
            <span style="color:var(--text-dim)">Disclosure Lag:</span> ${t.lagDays} days
          </div>
          <div>
            <span style="color:var(--text-dim)">90-Day Return:</span> <span class="${t.return90>=0?'positive':'negative'}">${fmtPct(t.return90)}</span><br>
            <span style="color:var(--text-dim)">90-Day Excess vs SPY:</span> <span class="${t.excess90>=0?'positive':'negative'}">${fmtPct(t.excess90)}</span><br>
            <span style="color:var(--text-dim)">Estimated Amount:</span> ${fmtMoney(t.amount)}<br>
            <span style="color:var(--text-dim)">Days Since Trade:</span> ${daysSince(t.date)}
          </div>
        </div>
      </td>
    </tr>`;
    return mainRow+detailRow;
  }).join('');
  document.getElementById('explorer-count').textContent=`Showing ${sorted.length} of ${TRADES.length} trades`;
}

function toggleDetail(btn,idx){
  const row=document.getElementById('detail-'+idx);
  if(row.classList.contains('open')){
    row.classList.remove('open');
    btn.textContent='+';
  }else{
    row.classList.add('open');
    btn.textContent='−';
  }
}

function filterExplorer(){
  const party=document.getElementById('filter-party').value;
  const sector=document.getElementById('filter-sector').value;
  const trader=document.getElementById('filter-trader').value;
  const type=document.getElementById('filter-type').value;
  const ticker=document.getElementById('filter-ticker').value.toUpperCase().trim();

  let filtered=TRADES.filter(t=>{
    if(party&&t.party!==party)return false;
    if(sector&&t.sector!==sector)return false;
    if(trader&&t.trader!==trader)return false;
    if(type&&t.type!==type)return false;
    if(ticker&&!t.ticker.includes(ticker))return false;
    return true;
  });
  renderExplorer(filtered);
}

/* ═══════════════════════════════
   TABLE SORTING
   ═══════════════════════════════ */

function sortTable(tableId,colIndex){
  const table=document.getElementById(tableId);
  const tbody=table.querySelector('tbody');
  const rows=Array.from(tbody.querySelectorAll('tr:not(.trade-detail-row)'));
  const th=table.querySelectorAll('th')[colIndex];
  const asc=th.dataset.sort!=='asc';
  table.querySelectorAll('th').forEach(h=>h.dataset.sort='');
  th.dataset.sort=asc?'asc':'desc';

  rows.sort((a,b)=>{
    let aVal=a.cells[colIndex].textContent.trim();
    let bVal=b.cells[colIndex].textContent.trim();
    const aNum=parseFloat(aVal.replace(/[^0-9.\-]/g,''));
    const bNum=parseFloat(bVal.replace(/[^0-9.\-]/g,''));
    if(!isNaN(aNum)&&!isNaN(bNum))return asc?aNum-bNum:bNum-aNum;
    return asc?aVal.localeCompare(bVal):bVal.localeCompare(aVal);
  });
  rows.forEach(r=>tbody.appendChild(r));
}

let explorerSortCol=-1,explorerSortAsc=true;
function sortExplorer(colIndex){
  if(explorerSortCol===colIndex)explorerSortAsc=!explorerSortAsc;
  else{explorerSortCol=colIndex;explorerSortAsc=true;}
  filterExplorer();
}

/* ═══════════════════════════════
   SIMULATOR
   ═══════════════════════════════ */

function lerp(t,points){
  const keys=Object.keys(points).map(Number).sort((a,b)=>a-b);
  if(t<=keys[0])return points[keys[0]];
  if(t>=keys[keys.length-1])return points[keys[keys.length-1]];
  for(let i=0;i<keys.length-1;i++){
    if(t>=keys[i]&&t<=keys[i+1]){
      const pct=(t-keys[i])/(keys[i+1]-keys[i]);
      return points[keys[i]]+(points[keys[i+1]]-points[keys[i]])*pct;
    }
  }
}

function updateSimulator(){
  const lag=parseInt(document.getElementById('sim-lag').value);
  const tradeType=document.querySelector('input[name="sim-type"]:checked').value;
  const perspective=document.querySelector('input[name="sim-perspective"]:checked').value;
  const party=document.getElementById('sim-party').value;

  document.getElementById('sim-lag-val').textContent=`T+${lag} days`;

  let data;
  if(tradeType==='purchase'){
    data=LAG_DATA.purchaseOnly;
  }else if(tradeType==='sale'){
    data=LAG_DATA.saleOnly;
  }else if(perspective==='copycat'){
    data=LAG_DATA.copycat;
  }else{
    data=LAG_DATA.insider;
  }

  // Interpolate from available data points
  const pts={};const meanPts={};const stdPts={};const wrPts={};const tPts={};const pPts={};
  data.forEach(d=>{
    pts[d.lag]=d.excess;meanPts[d.lag]=d.mean;stdPts[d.lag]=d.std;
    wrPts[d.lag]=d.winRate;tPts[d.lag]=d.t;pPts[d.lag]=d.p;
  });

  let excess=lerp(lag,pts);
  let raw=lerp(lag,meanPts);
  let winRate=lerp(lag,wrPts);
  let tStat=lerp(lag,tPts);
  let pVal=lerp(lag,pPts);

  // Party adjustment (from actual data)
  if(party==='R'){excess*=(7.10/3.40);raw*=1.3}
  else if(party==='D'){excess*=(-1.89/3.40);raw*=0.6}

  const sig=Math.abs(pVal)<0.05;

  const exEl=document.getElementById('sim-excess');
  exEl.textContent=fmtPct(excess);
  exEl.classList.toggle('neg',excess<0);
  document.getElementById('sim-raw').textContent=fmt(raw)+'%';
  document.getElementById('sim-winrate').textContent=fmt(winRate,1)+'%';
  document.getElementById('sim-tstat').textContent=fmt(tStat,3);
  document.getElementById('sim-pval').textContent=fmt(pVal,3);
  const sigEl=document.getElementById('sim-sig');
  sigEl.textContent=sig?'Yes (p<0.05)':'No';
  sigEl.style.color=sig?'var(--green)':'var(--amber)';

  initSimChart();
}

function initSimChart(){
  if(charts.sim)charts.sim.destroy();
  const ctx=document.getElementById('chart-sim');
  if(!ctx)return;

  const perspective=document.querySelector('input[name="sim-perspective"]:checked').value;
  const tradeType=document.querySelector('input[name="sim-type"]:checked').value;

  let data;
  if(tradeType==='purchase')data=LAG_DATA.purchaseOnly;
  else if(tradeType==='sale')data=LAG_DATA.saleOnly;
  else if(perspective==='copycat')data=LAG_DATA.copycat;
  else data=LAG_DATA.insider;

  const filtered=data.filter(d=>d.lag>0);
  const labels=filtered.map(d=>d.label);
  const means=filtered.map(d=>d.excess);
  const upper=filtered.map(d=>d.excess+(d.std/Math.sqrt(68)));
  const lower=filtered.map(d=>d.excess-(d.std/Math.sqrt(68)));

  charts.sim=new Chart(ctx.getContext('2d'),{
    type:'line',
    data:{
      labels:labels,
      datasets:[
        {
          label:'Mean Excess Return',
          data:means,
          borderColor:TEAL,backgroundColor:TEAL_BG,fill:false,
          tension:.3,pointRadius:5,pointBackgroundColor:TEAL,borderWidth:2.5,
        },
        {
          label:'+1σ / √n',
          data:upper,
          borderColor:'rgba(20,184,166,.3)',backgroundColor:'rgba(20,184,166,.08)',
          fill:'+1',tension:.3,pointRadius:0,borderWidth:1,borderDash:[4,4],
        },
        {
          label:'−1σ / √n',
          data:lower,
          borderColor:'rgba(20,184,166,.3)',backgroundColor:'rgba(20,184,166,.08)',
          fill:'-1',tension:.3,pointRadius:0,borderWidth:1,borderDash:[4,4],
        }
      ]
    },
    options:{
      ...baseOpts(),
      plugins:{
        ...baseOpts().plugins,
        legend:{display:true,labels:{...baseOpts().plugins.legend.labels,filter:function(item){return item.datasetIndex===0}}},
        tooltip:{
          ...baseOpts().plugins.tooltip,
          callbacks:{label:function(ctx){return ctx.dataset.label+': '+fmtPct(ctx.parsed.y)}}
        }
      },
      scales:{
        x:{...baseOpts().scales.x},
        y:{...baseOpts().scales.y,title:{display:true,text:'Excess Return (%)',color:tickColor(),font:{family:"'JetBrains Mono',monospace",size:11}}}
      }
    }
  });
}

/* ═══════════════════════════════
   ALERT SUBSCRIBE
   ═══════════════════════════════ */

function subscribeAlerts(){
  const email=document.getElementById('alert-email').value.trim();
  if(!email||!email.includes('@')){
    showToast('Please enter a valid email address');return;
  }
  let subs=JSON.parse(localStorage.getItem('congress-alpha-subs')||'[]');
  if(subs.includes(email)){
    showToast('Already subscribed!');return;
  }
  subs.push(email);
  localStorage.setItem('congress-alpha-subs',JSON.stringify(subs));
  document.getElementById('alert-email').value='';
  showToast('✓ Subscribed! You\'ll receive alerts for new congressional trades.');
}

/* ═══════════════════════════════
   SCROLL & NAV
   ═══════════════════════════════ */

function initScrollObserver(){
  const observer=new IntersectionObserver((entries)=>{
    entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')});
  },{threshold:0.08,rootMargin:'0px 0px -50px 0px'});
  document.querySelectorAll('.fade-in').forEach(el=>observer.observe(el));
}

function initActiveNav(){
  const sections=document.querySelectorAll('section[id],header[id]');
  const links=document.querySelectorAll('#sidebar-nav a');
  const observer=new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        links.forEach(l=>l.classList.remove('active'));
        const link=document.querySelector(`#sidebar-nav a[href="#${e.target.id}"]`);
        if(link)link.classList.add('active');
      }
    });
  },{threshold:0.2,rootMargin:'-80px 0px -60% 0px'});
  sections.forEach(s=>observer.observe(s));
  links.forEach(l=>l.addEventListener('click',()=>{
    document.querySelector('.sidebar').classList.remove('open');
  }));
}

/* ═══════════════════════════════
   INIT
   ═══════════════════════════════ */

document.addEventListener('DOMContentLoaded',()=>{
  populateTraderTable();
  populateRecentTrades();
  populateExplorer();
  initAllCharts();
  initScrollObserver();
  initActiveNav();
  updateSimulator();
  // Hide loading spinner
  const loader=document.getElementById('page-loader');
  if(loader){loader.classList.add('hidden');setTimeout(()=>loader.remove(),500);}
});
</script>
</body>
</html>