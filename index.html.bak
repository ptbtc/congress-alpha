<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Congressional Trading Alpha | Empirical Analysis of Disclosure-Lag Returns</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%230a0f1a'/%3E%3Cpolyline points='4,22 10,16 16,19 22,10 28,13' fill='none' stroke='%2314b8a6' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3Ccircle cx='28' cy='13' r='2' fill='%2314b8a6'/%3E%3C/svg%3E">
<meta property="og:type" content="article">
<meta property="og:title" content="Congressional Trading Alpha — Empirical Analysis of Disclosure-Lag Returns">
<meta property="og:description" content="68 trades, 36 members of Congress, 2020–2024. Does the alpha survive the mandatory reporting delay? Independent empirical research.">
<meta property="og:image" content="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1200 630'%3E%3Crect width='1200' height='630' fill='%230a0f1a'/%3E%3Ctext x='600' y='280' text-anchor='middle' fill='%2314b8a6' font-size='64' font-family='Georgia,serif' font-weight='700'%3ECongressional Trading Alpha%3C/text%3E%3Ctext x='600' y='370' text-anchor='middle' fill='%2394a3b8' font-size='28' font-family='Georgia,serif'%3EEmpirical Analysis of Disclosure-Lag Returns%3C/text%3E%3C/svg%3E">
<meta property="og:url" content="https://congress-alpha.research.dev">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Congressional Trading Alpha — Disclosure-Lag Returns">
<meta name="twitter:description" content="68 trades, 36 members of Congress, 2020–2024. Does the alpha survive the mandatory reporting delay?">
<meta name="twitter:image" content="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1200 630'%3E%3Crect width='1200' height='630' fill='%230a0f1a'/%3E%3Ctext x='600' y='280' text-anchor='middle' fill='%2314b8a6' font-size='64' font-family='Georgia,serif' font-weight='700'%3ECongressional Trading Alpha%3C/text%3E%3C/svg%3E">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Source+Serif+Pro:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" integrity="sha384-9nhczxUqK87bcKHh20fSQcTGD4qq5GhayNYSYWqwBkINBhOfQLg/P5HG5lF1urn4" crossorigin="anonymous"></script>
<script>if(typeof Chart==='undefined'){document.write('<script src="https://unpkg.com/chart.js@4.4.1/dist/chart.umd.min.js"><\/script>')}</script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0f1a;--bg2:#0f1629;--bg3:#141c33;--bg4:#1a2440;
  --teal:#14b8a6;--teal-dim:rgba(20,184,166,.15);--teal-glow:rgba(20,184,166,.25);
  --text:#e2e8f0;--text-dim:#94a3b8;--text-bright:#f1f5f9;
  --red:#ef4444;--green:#22c55e;--amber:#f59e0b;--purple:#a78bfa;
  --blue:#3b82f6;
  --border:#1e293b;--border-light:#2d3a56;
  --heading:'Playfair Display',Georgia,serif;
  --body:'Source Serif Pro',Georgia,serif;
  --mono:'JetBrains Mono','Fira Code',monospace;
  --sidebar-w:260px;
  --max-w:900px;
}
[data-theme="light"]{
  --bg:#f8fafc;--bg2:#f1f5f9;--bg3:#e2e8f0;--bg4:#cbd5e1;
  --text:#1e293b;--text-dim:#475569;--text-bright:#0f172a;
  --border:#cbd5e1;--border-light:#94a3b8;
  --teal-dim:rgba(20,184,166,.1);--teal-glow:rgba(20,184,166,.15);
}
html{scroll-behavior:smooth;font-size:16px}
body{
  font-family:var(--body);color:var(--text);background:var(--bg);
  line-height:1.75;-webkit-font-smoothing:antialiased;
  transition:background .3s,color .3s;
  font-feature-settings:'tnum' 1;
}

/* Sidebar */
.sidebar{
  position:fixed;top:0;left:0;width:var(--sidebar-w);height:100vh;
  background:var(--bg2);border-right:1px solid var(--border);
  overflow-y:auto;z-index:100;padding:2rem 0;transition:transform .3s;
}
.sidebar-logo{
  font-family:var(--heading);font-size:1.1rem;font-weight:700;
  color:var(--teal);padding:0 1.5rem 1.5rem;letter-spacing:-.02em;
  border-bottom:1px solid var(--border);margin-bottom:1rem;
}
.sidebar nav a{
  display:flex;align-items:center;gap:.6rem;
  padding:.55rem 1.5rem;font-size:.82rem;color:var(--text-dim);
  text-decoration:none;transition:all .2s;font-family:var(--body);
  border-left:2px solid transparent;
}
.sidebar nav a:hover,.sidebar nav a.active{
  color:var(--teal);background:var(--teal-dim);border-left-color:var(--teal);
}
.sidebar nav a .num{
  font-family:var(--mono);font-size:.7rem;color:var(--text-dim);
  min-width:1.4rem;opacity:.6;
}
.sidebar-toggle{
  display:none;position:fixed;top:1rem;left:1rem;z-index:200;
  background:var(--bg2);border:1px solid var(--border);border-radius:6px;
  color:var(--text);width:40px;height:40px;cursor:pointer;font-size:1.2rem;line-height:1;
}
@media(max-width:1024px){
  .sidebar{transform:translateX(-100%)}
  .sidebar.open{transform:translateX(0)}
  .sidebar-toggle{display:flex;align-items:center;justify-content:center}
  .main{margin-left:0!important}
}

/* Main Content */
.main{margin-left:var(--sidebar-w);min-height:100vh}
.content{max-width:var(--max-w);margin:0 auto;padding:0 2rem 6rem}

/* Top Bar */
.topbar{
  position:sticky;top:0;z-index:50;
  background:rgba(10,15,26,.85);backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  padding:.6rem 2rem;display:flex;align-items:center;justify-content:flex-end;gap:.8rem;
}
[data-theme="light"] .topbar{background:rgba(248,250,252,.85)}
.topbar button{
  background:none;border:1px solid var(--border);border-radius:6px;
  color:var(--text-dim);padding:.35rem .7rem;font-size:.75rem;cursor:pointer;
  font-family:var(--mono);transition:all .2s;
}
.topbar button:hover{border-color:var(--teal);color:var(--teal)}
.topbar .share-toast{
  position:absolute;right:2rem;top:3rem;background:var(--teal);color:#000;
  padding:.4rem .8rem;border-radius:6px;font-size:.75rem;font-family:var(--mono);
  opacity:0;transition:opacity .3s;pointer-events:none;
}
.topbar .share-toast.show{opacity:1}

/* Hero */
.hero{
  padding:6rem 0 4rem;text-align:center;
  background:linear-gradient(180deg,rgba(20,184,166,.06) 0%,transparent 60%);
  border-bottom:1px solid var(--border);margin-bottom:3rem;
}
.hero h1{
  font-family:var(--heading);font-size:2.6rem;font-weight:700;
  color:var(--text-bright);line-height:1.2;max-width:750px;margin:0 auto .8rem;
  letter-spacing:-.03em;
}
.hero .subtitle{
  font-family:var(--body);font-size:1.12rem;color:var(--text);opacity:.85;
  max-width:620px;margin:0 auto 1rem;font-style:italic;
  text-shadow:0 1px 8px rgba(0,0,0,.3);
}
.hero .meta{font-family:var(--mono);font-size:.78rem;color:var(--teal);letter-spacing:.08em;text-transform:uppercase}

.stat-cards{
  display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem;
  max-width:860px;margin:2.5rem auto 0;
}
.stat-card{
  background:var(--bg2);border:1px solid var(--border);border-radius:12px;
  padding:1.8rem 1.3rem;text-align:center;transition:border-color .3s,transform .2s,box-shadow .3s;
  position:relative;overflow:hidden;
}
.stat-card::before{
  content:'';position:absolute;inset:-1px;border-radius:13px;
  background:linear-gradient(135deg,var(--teal),var(--purple),var(--teal));
  background-size:300% 300%;animation:stat-glow 4s ease infinite;
  opacity:0;transition:opacity .3s;z-index:0;
}
.stat-card::after{
  content:'';position:absolute;inset:1px;border-radius:11px;
  background:var(--bg2);z-index:1;
}
.stat-card>*{position:relative;z-index:2}
.stat-card:hover::before{opacity:1}
.stat-card:hover{border-color:transparent;transform:translateY(-3px);box-shadow:0 8px 32px rgba(20,184,166,.15)}
@keyframes stat-glow{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
.stat-card .value{
  font-family:var(--mono);font-size:2rem;font-weight:700;
  color:var(--teal);line-height:1.2;
}
.stat-card .label{font-size:.78rem;color:var(--text-dim);margin-top:.5rem;line-height:1.4}

/* Sections */
section{padding:5rem 0 4rem;border-bottom:1px solid var(--border)}
section:last-of-type{border-bottom:none}
.section-num{
  font-family:var(--mono);font-size:.72rem;color:var(--teal);
  letter-spacing:.12em;text-transform:uppercase;margin-bottom:.5rem;
}
h2{
  font-family:var(--heading);font-size:2rem;font-weight:700;
  color:var(--text-bright);margin-bottom:1.5rem;letter-spacing:-.02em;
  line-height:1.3;
}
h3{
  font-family:var(--heading);font-size:1.35rem;font-weight:600;
  color:var(--text-bright);margin:2.5rem 0 1rem;
  line-height:1.4;
}
h4{
  font-family:var(--heading);font-size:1.1rem;font-weight:600;
  color:var(--text-bright);margin:1.8rem 0 .8rem;
  line-height:1.4;opacity:.9;
}
p{margin-bottom:1.2rem}
strong{color:var(--text-bright)}
.highlight{color:var(--teal);font-weight:600}
.mono{font-family:var(--mono)}

/* Charts */
.chart-container{
  background:var(--bg2);border:1px solid var(--border-light);border-radius:12px;
  padding:2rem;margin:2rem 0;position:relative;
  box-shadow:0 4px 24px rgba(0,0,0,.15);
}
.chart-container .chart-title{
  font-family:var(--heading);font-size:1.15rem;font-weight:700;
  color:var(--teal);margin-bottom:.4rem;letter-spacing:-.01em;
}
.chart-container .chart-subtitle{
  font-family:var(--body);font-size:.82rem;color:var(--text-dim);margin-bottom:1.2rem;
}
.chart-container canvas{max-height:380px}

/* Tables */
.table-wrap{overflow-x:auto;margin:2rem 0;border-radius:12px;border:1px solid var(--border-light);box-shadow:0 2px 12px rgba(0,0,0,.1)}
table{width:100%;border-collapse:collapse;font-size:.82rem}
thead{background:var(--bg3)}
th{
  font-family:var(--mono);font-weight:500;text-transform:uppercase;
  font-size:.7rem;letter-spacing:.08em;color:var(--text-dim);
  padding:1rem .9rem;text-align:left;cursor:pointer;
  user-select:none;white-space:nowrap;border-bottom:1px solid var(--border);
  transition:color .2s;
}
th:hover{color:var(--teal)}
th .sort-arrow{font-size:.6rem;margin-left:.3rem;opacity:.5}
td{
  padding:.85rem .9rem;border-bottom:1px solid var(--border);
  font-family:var(--body);font-size:.82rem;vertical-align:middle;
}
tr:last-child td{border-bottom:none}
tbody tr{transition:background .15s}
tbody tr:hover{background:var(--teal-dim)}
tbody tr:nth-child(even){background:rgba(255,255,255,.02)}
[data-theme="light"] tbody tr:nth-child(even){background:rgba(0,0,0,.02)}
tbody tr:nth-child(even):hover{background:var(--teal-dim)}
td.num{font-family:var(--mono);text-align:right}
.positive{color:var(--green)}
.negative{color:var(--red)}
.tag{
  display:inline-block;padding:.15rem .5rem;border-radius:4px;
  font-family:var(--mono);font-size:.68rem;
}
.tag-dem{background:rgba(59,130,246,.15);color:#60a5fa}
.tag-rep{background:rgba(239,68,68,.15);color:#f87171}

/* Methodology Callout */
.methodology-callout{
  background:var(--bg2);border:1px solid var(--amber);border-radius:10px;
  padding:1.5rem 2rem;margin:2rem 0;position:relative;overflow:hidden;
}
.methodology-callout::before{
  content:'📊';position:absolute;top:1.2rem;left:1.2rem;font-size:1.2rem;
}
.methodology-callout h4{
  margin:0 0 .8rem 2rem;color:var(--amber);font-family:var(--heading);
}
.methodology-callout ul{margin-left:2rem;font-size:.88rem}
.methodology-callout li{margin-bottom:.3rem;color:var(--text-dim)}

/* Simulator */
.simulator{
  background:var(--bg2);border:1px solid var(--teal);border-radius:12px;
  padding:2rem;margin:2rem 0;position:relative;overflow:hidden;
}
.simulator::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--teal),var(--purple),var(--teal));
}
.sim-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-top:1.5rem}
@media(max-width:700px){.sim-grid{grid-template-columns:1fr}}
.sim-controls label{
  display:block;font-family:var(--mono);font-size:.75rem;
  color:var(--text-dim);margin-bottom:.4rem;text-transform:uppercase;letter-spacing:.06em;
}
.sim-controls input[type="range"]{width:100%;accent-color:var(--teal);margin-bottom:.3rem;height:6px}
.sim-controls .range-val{font-family:var(--mono);font-size:1.1rem;color:var(--teal);font-weight:500}
.sim-controls .control-group{margin-bottom:1.5rem}
.sim-controls select{
  width:100%;padding:.5rem;background:var(--bg3);border:1px solid var(--border);
  border-radius:6px;color:var(--text);font-family:var(--mono);font-size:.82rem;
}
.sim-controls .checkbox-group{display:flex;gap:1rem;margin-top:.3rem;flex-wrap:wrap}
.sim-controls .checkbox-group label{
  display:flex;align-items:center;gap:.4rem;cursor:pointer;
  text-transform:none;font-size:.85rem;color:var(--text);
}
.sim-controls input[type="checkbox"]{accent-color:var(--teal)}
.sim-results{background:var(--bg3);border-radius:10px;padding:1.5rem}
.sim-result-item{
  display:flex;justify-content:space-between;align-items:baseline;
  padding:.7rem 0;border-bottom:1px solid var(--border);
}
.sim-result-item:last-child{border-bottom:none}
.sim-result-item .r-label{font-size:.82rem;color:var(--text-dim)}
.sim-result-item .r-value{font-family:var(--mono);font-size:1.3rem;font-weight:500;color:var(--teal)}
.sim-result-item .r-value.neg{color:var(--red)}
.sim-chart-container{margin-top:1.5rem}
.sim-chart-container canvas{max-height:300px}

/* Key Takeaway Callout */
.key-takeaway{
  border-left:4px solid var(--teal);background:rgba(20,184,166,.06);
  border-radius:0 10px 10px 0;padding:1.2rem 1.5rem;margin:1.5rem 0 2rem;
  font-size:.95rem;
}
.key-takeaway .kt-label{
  font-family:var(--mono);font-size:.68rem;text-transform:uppercase;
  letter-spacing:.12em;color:var(--teal);margin-bottom:.4rem;display:block;
}
.key-takeaway p{
  margin:0;font-weight:600;color:var(--text-bright);line-height:1.6;
}

/* Blockquotes */
blockquote{
  border-left:4px solid var(--teal);padding:1rem 1.5rem;margin:1.5rem 0;
  background:var(--teal-dim);border-radius:0 10px 10px 0;
  font-style:italic;color:var(--text-dim);
}
.citation{
  font-family:var(--body);font-size:.85rem;color:var(--text-dim);
  padding:.5rem 0;border-bottom:1px solid var(--border);margin-bottom:.5rem;
}
.citation strong{color:var(--text)}
ul,ol{margin:.8rem 0 1.2rem 1.5rem}
li{margin-bottom:.4rem}
li::marker{color:var(--teal)}

/* Recent Trades Section */
.trade-arrow{display:inline-block;font-weight:700;font-size:.9rem;margin-right:.3rem}
.trade-arrow.up{color:var(--green)}
.trade-arrow.down{color:var(--red)}

.alert-subscribe{
  background:var(--bg3);border:1px solid var(--border);border-radius:10px;
  padding:1.5rem;margin:1.5rem 0;display:flex;gap:1rem;align-items:center;flex-wrap:wrap;
}
.alert-subscribe input[type="email"]{
  flex:1;min-width:200px;padding:.6rem 1rem;background:var(--bg);border:1px solid var(--border);
  border-radius:6px;color:var(--text);font-family:var(--mono);font-size:.85rem;
}
.alert-subscribe input[type="email"]::placeholder{color:var(--text-dim)}
.alert-subscribe button{
  background:var(--teal);color:#000;border:none;padding:.6rem 1.5rem;
  border-radius:6px;font-family:var(--mono);font-size:.85rem;font-weight:600;
  cursor:pointer;transition:opacity .2s;white-space:nowrap;
}
.alert-subscribe button:hover{opacity:.85}

/* Trade Explorer */
.explorer-controls{
  display:flex;gap:.8rem;flex-wrap:wrap;margin-bottom:1rem;
}
.explorer-controls select,.explorer-controls input{
  padding:.5rem .8rem;background:var(--bg3);border:1px solid var(--border);
  border-radius:6px;color:var(--text);font-family:var(--mono);font-size:.8rem;
  min-width:140px;
}
.explorer-controls input{min-width:180px}
.explorer-controls input::placeholder{color:var(--text-dim)}
.trade-detail-row{display:none}
.trade-detail-row td{
  background:var(--bg3);padding:1rem;font-size:.8rem;line-height:1.6;
}
.trade-detail-row.open{display:table-row}
.expand-btn{
  cursor:pointer;color:var(--teal);font-family:var(--mono);font-size:.75rem;
  background:none;border:1px solid var(--teal);border-radius:4px;
  padding:.15rem .4rem;transition:all .2s;
}
.expand-btn:hover{background:var(--teal);color:#000}

/* Toast */
.toast{
  position:fixed;bottom:2rem;right:2rem;background:var(--teal);color:#000;
  padding:.8rem 1.5rem;border-radius:8px;font-family:var(--mono);font-size:.85rem;
  font-weight:600;z-index:1000;opacity:0;transform:translateY(20px);
  transition:opacity .3s,transform .3s;pointer-events:none;
}
.toast.show{opacity:1;transform:translateY(0)}

/* Confidence Band */
.ci-note{font-family:var(--mono);font-size:.72rem;color:var(--text-dim);margin-top:.5rem;text-align:center}

/* Footer */
footer{
  text-align:center;padding:4rem 2rem 3rem;border-top:1px solid var(--border);
  font-size:.78rem;color:var(--text-dim);font-family:var(--mono);
  line-height:2;
}
footer a{color:var(--teal);text-decoration:none}
footer .footer-meta{display:block;margin-bottom:.3rem}

/* Print */
@media print{
  .sidebar,.topbar,.sidebar-toggle,.simulator,.alert-subscribe,.explorer-controls,.expand-btn,.page-loader{display:none!important}
  .toast{display:none!important}
  canvas{max-height:300px!important}
  a[href]{text-decoration:none;color:inherit}
  section{page-break-before:auto;padding:2rem 0}
  .main{margin-left:0!important}
  body{background:#fff;color:#000;font-size:11pt}
  .hero{padding:2rem 0}
  h2{page-break-after:avoid}
  .chart-container,.table-wrap{page-break-inside:avoid}
  .stat-card{border:1px solid #ccc;box-shadow:none}
  .stat-card::before,.stat-card::after{display:none}
  .methodology-callout{border-color:#ccc}
  .key-takeaway{border-left-color:#333;background:#f0f0f0}
  .tag-dem{background:#dbeafe;color:#1e40af}
  .tag-rep{background:#fee2e2;color:#991b1b}
  .positive{color:#166534}
  .negative{color:#991b1b}
  tbody tr:nth-child(even){background:#f9fafb!important}
}

/* Responsive */
@media(max-width:600px){
  .hero h1{font-size:1.7rem}
  .stat-cards{grid-template-columns:repeat(2,1fr)}
  .content{padding:0 1rem 4rem}
  h2{font-size:1.4rem}
  .stat-card .value{font-size:1.3rem}
  .explorer-controls{flex-direction:column}
  .explorer-controls select,.explorer-controls input{min-width:100%}
  .alert-subscribe{flex-direction:column}
  .alert-subscribe input[type="email"]{min-width:100%}
}

/* Animations */
.fade-in{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
.fade-in.visible{opacity:1;transform:translateY(0)}

/* Loading Spinner */
.page-loader{position:fixed;inset:0;z-index:9999;background:var(--bg);display:flex;align-items:center;justify-content:center;transition:opacity .4s ease}
.page-loader.hidden{opacity:0;pointer-events:none}
.spinner{width:48px;height:48px;border:3px solid var(--border);border-top-color:var(--teal);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
</style>
</head>
<body>

<div class="page-loader" id="page-loader"><div class="spinner"></div></div>

<button class="sidebar-toggle" onclick="document.querySelector('.sidebar').classList.toggle('open')" aria-label="Toggle navigation">☰</button>

<aside class="sidebar">
  <div class="sidebar-logo">Congressional<br>Trading Alpha</div>
  <nav id="sidebar-nav">
    <a href="#hero"><span class="num">00</span>Overview</a>
    <a href="#executive-summary"><span class="num">01</span>Executive Summary</a>
    <a href="#introduction"><span class="num">02</span>Introduction</a>
    <a href="#literature"><span class="num">03</span>Literature Review</a>
    <a href="#methodology"><span class="num">04</span>Data &amp; Methodology</a>
    <a href="#findings"><span class="num">05</span>Findings</a>
    <a href="#simulator"><span class="num">06</span>Portfolio Simulator</a>
    <a href="#discussion"><span class="num">07</span>Discussion</a>
