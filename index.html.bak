            <label><input type="radio" name="sim-type" value="purchase" onchange="updateSimulator()"> Purchases Only</label>
            <label><input type="radio" name="sim-type" value="sale" onchange="updateSimulator()"> Sales Only</label>
          </div>
        </div>
