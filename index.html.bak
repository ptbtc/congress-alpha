          <label>Party Filter</label>
          <select id="sim-party" onchange="updateSimulator()">
            <option value="all">Both Parties</option>
            <option value="R">Republicans Only</option>
            <option value="D">Democrats Only</option>
          </select>
        </div>
      </div>
      <div class="sim-results">
