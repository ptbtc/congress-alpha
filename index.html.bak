            <label><input type="radio" name="sim-perspective" value="insider" checked onchange="updateSimulator()"> Insider (Trade Date)</label>
            <label><input type="radio" name="sim-perspective" value="copycat" onchange="updateSimulator()"> Copycat (Disclosure)</label>
          </div>
        </div>
