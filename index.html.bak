<!-- Hero -->
<header class="hero" id="hero">
  <div class="meta">Independent Empirical Research &nbsp;·&nbsp; March 2026</div>
  <h1>Congressional Trading Alpha: An Empirical Analysis of Disclosure-Lag Returns</h1>
  <p class="subtitle">68 high-profile trades. 36 members of Congress. 2020–2024. Does the alpha survive the mandatory reporting delay?</p>
  <div class="stat-cards">
    <div class="stat-card fade-in">
      <div class="value">+3.40%</div>
      <div class="label">Mean Excess Return<br>90-Day (All Trades)</div>
    </div>
    <div class="stat-card fade-in">
      <div class="value">+4.16%</div>
